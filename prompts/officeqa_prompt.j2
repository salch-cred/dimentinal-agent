Write and execute a Python script to find all data files:

```python
import os
search_dirs = ['./data', '/data', '/workspace/data', '/workspace', './corpus', '/corpus', './sample_data', '.']
found = []
for d in search_dirs:
    if os.path.isdir(d):
        for root, dirs, files in os.walk(d):
            for f in files:
                if f.endswith(('.xlsx', '.xlsm', '.csv', '.pdf', '.txt', '.json')):
                    full = os.path.join(root, f)
                    found.append((full, os.path.getsize(full)))
for path, size in sorted(found):
    print(f"{size:>10} bytes  {path}")
```

